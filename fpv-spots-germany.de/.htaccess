# Security Headers
<IfModule mod_headers.c>
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' cdn.jsdelivr.net unpkg.com; style-src 'self' cdn.jsdelivr.net; img-src 'self' data: *.tile.openstreetmap.org server.arcgisonline.com /public/uploads/; font-src 'self' cdn.jsdelivr.net; connect-src 'self'"
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Service Worker: kein Cache, damit Updates sofort greifen
<IfModule mod_headers.c>
    <Files "sw.js">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Service-Worker-Allowed "/"
    </Files>
</IfModule>

# HTTPS erzwingen (aktivieren sobald SSL-Zertifikat eingerichtet ist)
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

RewriteEngine On

# Leerzeichen am Ende des URL-Pfads entfernen (literal und %20-kodiert)
RewriteCond %{THE_REQUEST} ^[A-Z]+\s(.*?)(%20|\ )+(\?[^\s]*)?\sHTTP/ [NC]
RewriteRule ^ %1%3 [R=301,L,NE]

# /index.php aus URL entfernen
DirectoryIndex index.php
RewriteCond %{THE_REQUEST} /index\.php[\s?/] [NC]
RewriteRule ^index\.php$ / [L,R=301]

# /public/php/X.php → /X.php umleiten (301)
RewriteCond %{THE_REQUEST} /public/php/([a-zA-Z0-9_-]+\.php)[\s?] [NC]
RewriteRule ^ /%1 [L,R=301]

# /public/html/errors/X.html → /X.html umleiten (301)
RewriteCond %{THE_REQUEST} /public/html/errors/([a-zA-Z0-9_-]+\.html)[\s?] [NC]
RewriteRule ^ /%1 [L,R=301]

# Clean URLs: /dateiname.php → public/php/[unterordner]/dateiname.php (intern)
RewriteCond %{REQUEST_URI} ^/([a-zA-Z0-9_-]+\.php)$ [NC]
RewriteCond %{DOCUMENT_ROOT}/public/php/auth/%1 -f
RewriteRule ^([a-zA-Z0-9_-]+\.php)$ public/php/auth/$1 [L,QSA]

RewriteCond %{REQUEST_URI} ^/([a-zA-Z0-9_-]+\.php)$ [NC]
RewriteCond %{DOCUMENT_ROOT}/public/php/account/%1 -f
RewriteRule ^([a-zA-Z0-9_-]+\.php)$ public/php/account/$1 [L,QSA]

RewriteCond %{REQUEST_URI} ^/([a-zA-Z0-9_-]+\.php)$ [NC]
RewriteCond %{DOCUMENT_ROOT}/public/php/spots/%1 -f
RewriteRule ^([a-zA-Z0-9_-]+\.php)$ public/php/spots/$1 [L,QSA]

RewriteCond %{REQUEST_URI} ^/([a-zA-Z0-9_-]+\.php)$ [NC]
RewriteCond %{DOCUMENT_ROOT}/public/php/community/%1 -f
RewriteRule ^([a-zA-Z0-9_-]+\.php)$ public/php/community/$1 [L,QSA]

RewriteCond %{REQUEST_URI} ^/([a-zA-Z0-9_-]+\.php)$ [NC]
RewriteCond %{DOCUMENT_ROOT}/public/php/contact/%1 -f
RewriteRule ^([a-zA-Z0-9_-]+\.php)$ public/php/contact/$1 [L,QSA]

RewriteCond %{REQUEST_URI} ^/([a-zA-Z0-9_-]+\.php)$ [NC]
RewriteCond %{DOCUMENT_ROOT}/public/php/legal/%1 -f
RewriteRule ^([a-zA-Z0-9_-]+\.php)$ public/php/legal/$1 [L,QSA]

# Clean URLs: /dateiname.html → public/html/errors/dateiname.html (intern)
RewriteCond %{REQUEST_URI} ^/([a-zA-Z0-9_-]+\.html)$ [NC]
RewriteCond %{DOCUMENT_ROOT}/public/html/errors/%1 -f
RewriteRule ^([a-zA-Z0-9_-]+\.html)$ public/html/errors/$1 [L,QSA]
